---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Reiserücktrittsversicherung Vergleich 2026 – Beste Tarife im Überblick"
  description="Vergleichen Sie Reiserücktrittsversicherungen und finden Sie den optimalen Schutz für Ihre Reise. Unabhängiger Vergleich aller Anbieter und Tarife."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Reiserücktrittsversicherung Vergleich 2026
        </h1>
        <p class="text-xl md:text-2xl mb-8 text-blue-100">
          Finden Sie den besten Schutz für Ihre Reise – schnell, einfach und transparent
        </p>
        <a
          href="/vergleich"
          class="inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-blue-50 transition-colors"
        >
          Jetzt Tarife vergleichen
        </a>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="prose prose-lg max-w-none">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">
        Warum eine Reiserücktrittsversicherung wichtig ist
      </h2>
      <p class="text-gray-700 text-lg leading-relaxed mb-4">
        Eine Reiserücktrittsversicherung schützt Sie vor hohen Stornokosten, wenn Sie Ihre Reise unerwartet
        absagen müssen. Ob Krankheit, Unfall oder berufliche Gründe – ohne den richtigen Versicherungsschutz
        bleiben Sie auf den Kosten sitzen.
      </p>
      <p class="text-gray-700 text-lg leading-relaxed">
        Unser unabhängiger Vergleich hilft Ihnen, die passende Reiserücktrittsversicherung zu finden.
        Vergleichen Sie Leistungen, Preise und Konditionen der führenden Anbieter.
      </p>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
        Unsere Vorteile für Sie
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Unabhängiger Vergleich</h3>
          <p class="text-gray-600">
            Wir vergleichen alle relevanten Anbieter objektiv und zeigen Ihnen die besten Optionen.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Günstige Preise</h3>
          <p class="text-gray-600">
            Finden Sie den besten Tarif zum günstigsten Preis – ohne versteckte Kosten.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Schnell & Einfach</h3>
          <p class="text-gray-600">
            In wenigen Minuten den passenden Tarif finden und direkt online abschließen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ad Space - Sidebar Placeholder -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content Area -->
        <div class="lg:col-span-2">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">
            Was deckt eine Reiserücktrittsversicherung ab?
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6 mb-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Typische Leistungen:</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700"><strong>Krankheit oder Unfall:</strong> Wenn Sie oder Ihre Reisebegleitung erkranken</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700"><strong>Schwangerschaftskomplikationen:</strong> Bei unerwarteten Schwangerschaftsproblemen</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700"><strong>Todesfall:</strong> Tod eines nahen Angehörigen</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700"><strong>Arbeitsplatzverlust:</strong> Unverschuldeter Verlust des Arbeitsplatzes</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700"><strong>Schäden am Eigentum:</strong> Erhebliche Schäden durch Feuer, Naturkatastrophen etc.</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Sidebar Ad Space -->
        <div class="lg:col-span-1">
          <div class="bg-white border-2 border-dashed border-gray-300 rounded-lg p-6 h-96 flex items-center justify-center text-gray-400 text-sm sticky top-24">
            Werbefläche (300x600)
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-blue-600 text-white py-16">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Bereit für den Vergleich?
      </h2>
      <p class="text-xl mb-8 text-blue-100">
        Starten Sie jetzt den kostenlosen Vergleich und finden Sie die beste Reiserücktrittsversicherung für Ihre Bedürfnisse.
      </p>
      <a
        href="/vergleich"
        class="inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-blue-50 transition-colors"
      >
        Zum Vergleichsrechner
      </a>
    </div>
  </section>
</Layout>
